---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio" activePage="inicio">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-teal-600 via-teal-500 to-teal-400">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 w-32 h-32 bg-white rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-48 h-48 bg-white rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight" data-sc="hero_title">
          Tu salud en las mejores manos
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-teal-100 max-w-2xl mx-auto" data-sc="hero_subtitle">
          Gestionamos tus turnos de manera simple y rapida. Reserva online en cualquier momento.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/turnos" class="px-8 py-3 rounded-xl bg-white text-teal-700 font-semibold shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300">
            Pedir turno online
          </a>
          <a href="/contacto" class="px-8 py-3 rounded-xl bg-white/10 text-white font-semibold border border-white/20 hover:bg-white/20 transition-all">
            Contacto
          </a>
        </div>
        <div class="mt-8 flex items-center justify-center gap-8 text-teal-100 text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Lun-Vie <span data-sc="hours_weekday">8:00 - 20:00</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Tel: <span data-sc="phone">(011) 1234-5678</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- CTA -->
    <section class="py-16">
      <div class="bg-gradient-to-br from-teal-600 to-teal-500 rounded-3xl p-8 sm:p-12 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3" data-sc="cta_title">Necesitas un turno?</h2>
        <p class="text-teal-100 mb-6 max-w-lg mx-auto" data-sc="cta_subtitle">Reserva tu turno online o contactanos por WhatsApp. Estamos para ayudarte.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/turnos" class="px-8 py-3 rounded-xl bg-white text-teal-700 font-semibold shadow-lg hover:shadow-xl transition-all">
            Pedir turno
          </a>
          <a href="https://wa.me/5491112345678" target="_blank" rel="noopener noreferrer" class="px-8 py-3 rounded-xl bg-[#25d366] text-white font-semibold hover:bg-[#1ebe57] transition-colors" data-sc-wa>
            WhatsApp
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
